{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Python File (Project Stable)",
      "type": "debugpy",
      "request": "launch",

      "program": "${file}",
      "cwd": "${workspaceFolder}/src",

      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },

      "console": "integratedTerminal"
    }
  ]
}